---
import Layout from "../layouts/Layout.astro";
import StoreButtons from "../components/StoreButtons.astro";
import { SITE, FEATURES } from "../lib/config";

const base = import.meta.env.BASE_URL;
---

<Layout title="Bahrista" description={SITE.tagline}>
  <section class="hero">
    <img
      src={`${base}favicon.svg`}
      alt=""
      class="hero__logo"
      width="96"
      height="96"
    />
    <h1>{SITE.name}</h1>
    <p class="hero__tagline">{SITE.tagline}</p>
    <p class="hero__intro">
      Registre, compare e organize os cafés especiais que você prova — com
      vocabulário sensorial, listas pessoais e escaneamento de rótulo no
      aparelho.
    </p>
    <StoreButtons />
  </section>

  <section class="features" aria-labelledby="features-heading">
    <h2 id="features-heading" class="visually-hidden">Recursos</h2>
    {
      FEATURES.map((feature) => (
        <article class="feature-card">
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </article>
      ))
    }
  </section>
</Layout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
