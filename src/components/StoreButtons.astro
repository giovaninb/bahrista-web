---
import { PLAY_STORE_URL, TESTFLIGHT_URL } from "../lib/config";
const base = import.meta.env.BASE_URL;
---

<div class="store-buttons">
  <a
    class="store-buttons__link"
    href={PLAY_STORE_URL}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Baixar Bahrista na Google Play"
  >
    <img
      src={`${base}images/store-badges/google-play.png`}
      alt="Disponível no Google Play"
      width="646"
      height="250"
      class="store-buttons__badge store-buttons__badge--play"
    />
  </a>
  <a
    class="store-buttons__link store-buttons__link--stacked"
    href={TESTFLIGHT_URL}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Testar Bahrista no TestFlight (iOS)"
  >
    <img
      src={`${base}images/store-badges/app-store.svg`}
      alt="Baixar na App Store"
      width="250"
      height="83"
      class="store-buttons__badge store-buttons__badge--apple"
    />
    <span class="store-buttons__beta-label">Beta no TestFlight</span>
  </a>
</div>
