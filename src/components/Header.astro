---
import { SITE } from "../lib/config";
import BahristaLogo from "./BahristaLogo.astro";
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={base} class="site-logo">
      <BahristaLogo size={48} class="site-logo__icon" variant="round" />
      <span class="site-logo__name">{SITE.name}</span>
    </a>
    <nav class="site-nav" aria-label="Principal">
      <a href={`${base}privacy/`}>Privacidade</a>
      <a href={`${base}terms/`}>Termos</a>
    </nav>
  </div>
</header>
